# =============================================================================
# GAMING BOOST — Variáveis de Ambiente (Template)
# Copie este arquivo para .env.local e preencha os valores reais.
# NÃO commite .env nem .env.local — ambos estão no .gitignore.
# =============================================================================

# --- Banco de dados ---
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# --- Auth / JWT ---
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=your-jwt-secret-min-32-chars

# --- App URLs ---
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Criptografia (AES-256 para credenciais Steam) ---
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-hex-chars-encryption-key-here-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Cron ---
CRON_SECRET=your-cron-secret

# --- Asaas ---
# Chave de API (Produção: painel Asaas > Integrações > API)
# Sandbox: https://sandbox.asaas.com > Integrações > API
ASAAS_API_KEY=your-asaas-api-key
# Token de autenticação do webhook (configurado no painel Asaas > Integrações > Webhooks)
ASAAS_WEBHOOK_SECRET=your-asaas-webhook-secret

# --- AbacatePay ---
ABACATEPAY_WEBHOOK_SECRET=your-abacatepay-webhook-secret
ABACATEPAY_API_KEY=your-abacatepay-api-key

# --- Configuração de Pagamento Global ---
# Defina o provedor padrão (ASAAS ou ABACATEPAY)
ACTIVE_PAYMENT_PROVIDER=ASAAS

# --- Email (Resend) ---
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=FlautasBoost <noreply@seudominio.com>

# --- Uploads (Vercel Blob) ---
BLOB_READ_WRITE_TOKEN=vercel_blob_your-token

# --- Configuração ---
ORDER_TIMEOUT_HOURS=24

# --- Opcionais ---
JWT_EXPIRES_IN=7d
