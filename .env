# =============================================================================
# GAMING BOOST — Variáveis de Ambiente (Template)
# Copie este arquivo para .env.local e preencha os valores reais.
# NÃO commite .env.local — ele já está no .gitignore.
# =============================================================================

# --- Banco de dados ---
DATABASE_URL=postgresql://user:password@localhost:5432/gaming_boost

# --- Auth / JWT ---
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=your-jwt-secret-min-32-chars

# --- App URLs ---
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Criptografia (AES-256 para credenciais Steam) ---
# Gere com: node -e "require('crypto').randomBytes(32).toString('hex')|console.log"
ENCRYPTION_KEY=your-64-hex-chars-encryption-key-here-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Cron ---
CRON_SECRET=your-cron-secret

# --- AbacatePay ---
ABACATEPAY_WEBHOOK_SECRET=your-abacatepay-webhook-secret
ABACATEPAY_API_KEY=your-abacatepay-api-key

# --- Email (Resend) ---
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=GameBoost <noreply@seudominio.com>

# --- Uploads (Vercel Blob) ---
BLOB_READ_WRITE_TOKEN=vercel_blob_your-token

# --- Configuração ---
ORDER_TIMEOUT_HOURS=24
CRON_SECRET=your-cron-secret

# --- Opcionais ---
# JWT_EXPIRES_IN=7d
# LEETIFY_API_KEY=your-leetify-api-key
