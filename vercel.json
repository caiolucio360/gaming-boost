{
  "buildCommand": "prisma generate && npm run build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/auto-refund",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/cleanup-blob",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/cleanup-unverified",
      "schedule": "0 4 * * *"
    }
  ]
}